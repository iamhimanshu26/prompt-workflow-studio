# Database (local Docker — see docker-compose.yml)
DATABASE_URL="postgresql://pws:pws_dev@localhost:5432/prompt_workflow_studio?schema=public"

# App
NEXT_PUBLIC_APP_NAME="Prompt Workflow Studio"
# Production: https://prompt-workflow-studio.vercel.app (not the docs placeholder your-app.vercel.app)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# AI providers (Phase 2+ — leave empty to use mock)
AI_PROVIDER="mock"
OPENAI_API_KEY=""
GEMINI_API_KEY=""

# Auth (Phase 1 — mock; Phase 9 — NextAuth)
AUTH_MODE="mock"
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
